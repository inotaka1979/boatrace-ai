{
  "name": "boatrace-ai-build",
  "version": "0.1.0",
  "description": "Build pipeline scaffold for BoatRace Oracle PWA (PC-7b)",
  "private": true,
  "type": "module",
  "scripts": {
    "presplit": "echo '[prebuild] splitting app.js -> app-critical.js / app-rest.js'",
    "split": "python3 ../scripts/split_app.py",
    "prebuild": "npm run split",
    "build": "node build.mjs",
    "prebuild:check": "npm run split",
    "build:check": "node build.mjs --check",
    "lint": "echo 'lint not yet configured'",
    "typecheck": "echo 'typecheck not yet configured'",
    "test:smoke": "playwright test --config playwright.config.mjs --project=webkit-smoke",
    "test:vrt": "playwright test --config playwright.config.mjs --project=chromium-vrt",
    "test:e2e": "playwright test --config playwright.config.mjs",
    "test:vrt:update": "playwright test --config playwright.config.mjs --project=chromium-vrt --update-snapshots"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "@playwright/test": "^1.48.0"
  },
  "dependencies": {
    "lighthouse": "^12.8.2"
  }
}
